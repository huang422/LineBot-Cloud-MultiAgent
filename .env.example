# ============================================================
# LINE API（必要）
# ============================================================
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_access_token

# ============================================================
# OpenRouter API（必要）
# https://openrouter.ai/keys 取得免費 API Key
# Orchestrator 主力模型與 OpenRouter fallback 會用到這把 key
# ============================================================
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_REASONING_ENABLED=true
# effort: xhigh | high | medium | low | minimal | none
OPENROUTER_REASONING_EFFORT=high
# exclude=true: model still reasons but reasoning not in response (saves tokens)
OPENROUTER_REASONING_EXCLUDE=true
# Only route to models marked as reasoning-capable in model_registry
REQUIRE_REASONING_MODELS=true
# Warn when a reasoning-capable model returns zero reasoning tokens / no reasoning content
REQUIRE_REASONING_TOKENS=true

# ============================================================
# NVIDIA API（建議，大幅提升品質）
# https://build.nvidia.com 免費申請 API Key
# Agent 主力模型；Orchestrator fallback 與圖片生成功能也會用到
# ============================================================
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_MODEL=qwen/qwen3.5-397b-a17b
NVIDIA_THINKING_ENABLED=true
NVIDIA_THINKING_BUDGET=4096

# ============================================================
# Orchestrator 設定（路由調度）
# 預設：主要走 OpenRouter Nemotron，fallback 走 NVIDIA Qwen3.5
# ============================================================
ORCHESTRATOR_MODEL=nvidia/nemotron-3-super-120b-a12b:free
ORCHESTRATOR_FALLBACK_MODEL=qwen/qwen3.5-397b-a17b
ORCHESTRATOR_TEMPERATURE=0
ORCHESTRATOR_MAX_TOKENS=200

# ============================================================
# Agent 統一 fallback（所有功能 Agent 共用）
# 主要：NVIDIA Qwen3.5 → fallback：OpenRouter Nemotron
# ============================================================
AGENT_FALLBACK_MODEL=nvidia/nemotron-3-super-120b-a12b:free
VISION_FALLBACK_MODEL=google/gemma-3-27b-it:free

# ============================================================
# Per-Agent 溫度和 Token 限制
# ============================================================
CHAT_TEMPERATURE=0.7
CHAT_MAX_TOKENS=2048

VISION_TEMPERATURE=0.5
VISION_MAX_TOKENS=1024

WEB_SEARCH_TEMPERATURE=0.3
WEB_SEARCH_MAX_TOKENS=3072

IMAGE_GEN_TEMPERATURE=0.7
IMAGE_GEN_MAX_TOKENS=1024

# --- Image Gen Stage 2（NVIDIA Stable Diffusion）---
IMAGE_GEN_PRIMARY_MODEL=stabilityai/stable-diffusion-3-medium
IMAGE_GEN_FALLBACK_MODEL=
IMAGE_GEN_STEPS=50
IMAGE_GEN_CFG_SCALE=5

# ============================================================
# 成本保護
# 一般回覆會先 reply，reply 不可用時可 fallback 到 push
# 排程訊息會直接使用 push；若想保留上限再設 monthly limit
# ============================================================
# true = 允許一般回覆在 reply 失敗時 fallback 到 push
LINE_PUSH_FALLBACK_ENABLED=true
# 0 = direct push 不設月上限（排程可直接送）；>0 = 每月 direct push 上限
LINE_PUSH_MONTHLY_LIMIT=0

# ============================================================
# GCP Cloud Storage（語音+圖片暫存公開 URL）
# Signed URL 預設 48 小時失效；物件預設 2 天後由應用程式排程刪除
# 部署腳本也會檢查 / 補上 bucket 3 天 lifecycle 作為保底刪除
# GOOGLE_APPLICATION_CREDENTIALS is read by GCP SDK from env automatically
# On Cloud Run, use the runtime service account instead of a local JSON file
# 一般雲端部署請保持空白，避免把本機金鑰路徑帶進服務設定
# ============================================================
GCS_BUCKET_NAME=
GCS_SIGNED_URL_EXPIRY_HOURS=48
GCS_MEDIA_CLEANUP_DELAY_SECONDS=172800
GOOGLE_APPLICATION_CREDENTIALS=

# ============================================================
# Tavily 網路搜尋（可選，https://tavily.com 取得免費 Key）
# ============================================================
TAVILY_API_KEY=your_tavily_api_key
WEB_SEARCH_MONTHLY_QUOTA=1000

# ============================================================
# TTS 語音設定（edge-tts 完全免費）
# 可用語音列表: https://github.com/rany2/edge-tts
# ============================================================
TTS_VOICE=zh-TW-HsiaoChenNeural
TTS_ENABLED=true

# ============================================================
# 機器人設定
# ============================================================
BOT_NAME=Assistant
# 可選：若要精準判斷 LINE mention 是否真的提到機器人，可填入 bot 的 LINE userId
LINE_BOT_USER_ID=

# ============================================================
# 排程訊息（群組定期提醒 + 生日祝福）
# 注意：排程訊息永遠使用 push，必須先開啟 LINE_PUSH_FALLBACK_ENABLED
# LINE_PUSH_MONTHLY_LIMIT=0 代表不設上限；若想控管再改成 >0
# SCHEDULED_WEEKLY_MESSAGES / SCHEDULED_YEARLY_MESSAGES 請填 JSON 陣列
# 若想換行排版，請用單引號包住整段 JSON
# ============================================================
SCHEDULED_MESSAGES_ENABLED=false
# LINE 群組 ID（從 webhook log 中取得，群組發訊息時會記錄）
# 格式: C1234567890abcdef1234567890abcdef
SCHEDULED_GROUP_ID=
SCHEDULED_WEEKLY_MESSAGES=[]
SCHEDULED_YEARLY_MESSAGES=[]
# 範例：
# SCHEDULED_WEEKLY_MESSAGES='[
#   {"id":"monday_workout_reminder","day_of_week":"mon","hour":21,"minute":0,"message":"Hi"},
#   {"id":"pineapple_workout_reminder","day_of_week":"mon","hour":21,"minute":30,"message":"Hi"}
# ]'
# SCHEDULED_YEARLY_MESSAGES='[
#   {"id":"birthday_reminder_0312","month":3,"day":12,"hour":9,"minute":0,"message":"Hi"}
# ]'

# ============================================================
# 對話與限制
# ============================================================
MAX_CONVERSATION_HISTORY=10
CONVERSATION_TTL_SECONDS=3600
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================
# 伺服器
# ============================================================
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# ============================================================
# 雲端部署（deploy_cloud_run.sh 讀取這些設定）
# ============================================================
# 設好後就可以直接執行 ./scripts/deploy_cloud_run.sh
# CLOUD_RUN_MIN_INSTANCES 留空 = 自動判斷（有排程 job 時預設 1，否則 0）
# 想更乾淨可把 DEPLOY_KEEP_IMAGES 改成 1；若想保留回滾空間可調大
GCP_PROJECT_ID=your_project_id
CLOUD_RUN_SERVICE_NAME=linebot-cloud-agent
CLOUD_RUN_REGION=us-west1
CLOUD_RUN_MIN_INSTANCES=
CLOUD_RUN_SERVICE_ACCOUNT=
DEPLOY_KEEP_REVISIONS=1
DEPLOY_KEEP_IMAGES=3
DEPLOY_ENABLE_APIS=true
